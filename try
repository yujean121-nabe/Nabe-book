const SKIN_TYPES_INFO = {
  normal: {
    name: "中性肌膚",
    subtitle: "水多油少",
    desc: "理想的油水平衡肌，毛孔細小不明顯，表面平滑細緻，氣色紅潤有光澤。",
    focus: "預防勝於治療。維持現狀，加強防曬與基礎保濕。",
